# Copy to .env and fill in — `.env` is gitignored, never commit real secrets.
# Used by docker-compose.yml when you need to inject credentials at runtime.

# Exporter image tag (GHCR). Pin a release for production instead of :latest.
OBS_TAG=latest

# Password for the ECS monitoring user. config.yaml references it as ${ECS01_PASSWORD}.
ECS01_PASSWORD=changeme

# Optional: override host and username via env (single-cluster convenience).
# config.yaml is always the source of truth; these are only substituted when
# config.yaml contains the matching ${VAR} reference.
# ECS01_HOSTNAME=ecs01.example.com
# ECS01_USERNAME=ecs-monitor

# Grafana admin login.
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme

# Public URL Grafana is served at — needed so login redirects and share links
# resolve correctly when accessed remotely.
GF_SERVER_ROOT_URL=http://your-server.example.com:3000
