# Copy to .env and fill in — `.env` is gitignored, never commit real secrets.
# Compose reads .env natively, and the exporter binary itself loads .env from the
# working directory (or next to config.yaml). Already-set environment variables
# always take precedence over .env values.
#
# Single-cluster quickstart: config.yaml references these variables.
# config.yaml is the source of truth — for multiple clusters add one entry per
# cluster there (literal values or your own ${OBS2_*} refs).

# ObjectScale / ECS management hostname or IP. config.yaml: ${OBS1_HOSTNAME}
OBS1_HOSTNAME=ecs01.example.com

# Monitoring user. config.yaml: ${OBS1_USERNAME}
OBS1_USERNAME=ecs-monitor

# Monitoring user password. config.yaml references it as ${OBS1_PASSWORD}.
# Special characters: wrap the value in single quotes so it is taken literally, e.g.
# OBS1_PASSWORD='p@$$w0rd!#{}'. Double quotes expand $VAR and process backslashes;
# unquoted values treat " #" (space-hash) as a comment. For a literal ' use double
# quotes ("p'ass"); for a " use single quotes ('p"ass'); for both, a backslash, or a
# value starting with a quote, use passwordFile in config.yaml instead (read verbatim).
OBS1_PASSWORD=changeme

# Skip TLS certificate verification for the cluster (INSECURE — dev/test only,
# self-signed certs). config.yaml can reference it as ${OBS1_SKIP_CERTIFICATE};
# defaults to false when unset. Leave unset/false in production.
OBS1_SKIP_CERTIFICATE=false
