          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ecs_cluster_transaction_read_bandwidth_mb_per_second{cluster=~\"$cluster\"}",
          "legendFormat": "read {{cluster}}",
          "refId": "A"
        },
        {
          "datasource": {
