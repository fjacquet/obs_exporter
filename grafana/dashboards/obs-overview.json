          },
          "expr": "ecs_cluster_bad_disks{cluster=~\"$cluster\"}",
          "legendFormat": "bad {{cluster}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Unacknowledged alerts by severity",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 14,
        "y": 1
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "spanNulls": false
          },
          "links": [
            {
              "title": "Open Maintenance & DT",
              "url": "/d/obs-maintenance?${__url_time_range}&var-cluster=${cluster}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "last",
            "max"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ecs_cluster_alerts_unacknowledged{cluster=~\"$cluster\"}",
          "legendFormat": "{{cluster}} {{severity}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Max RPO lag",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max(ecs_replication_group_rpo_lag_seconds{cluster=~\"$cluster\"})",
          "legendFormat": "max RPO",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 300
              },
              {
                "color": "red",
                "value": 900
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "links": [
            {
              "title": "Open Replication",
              "url": "/d/obs-replication?${__url_time_range}&var-cluster=${cluster}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "type": "row",
      "title": "Capacity runway",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "panels": [],
      "id": 101
    },
    {
      "id": 6,
      "type": "gauge",
      "title": "Capacity used %",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "percent",
          "max": 100,
          "min": 0,
          "links": [
            {
              "title": "Open Namespaces",
              "url": "/d/obs-namespaces?${__url_time_range}&var-cluster=${cluster}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * (1 - ecs_cluster_disk_space_free_bytes{cluster=~\"$cluster\"} / ecs_cluster_disk_space_total_bytes{cluster=~\"$cluster\"})",
          "legendFormat": "{{cluster}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Cluster disk space",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 6,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "spanNulls": false
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "last",
            "max"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ecs_cluster_disk_space_total_bytes{cluster=~\"$cluster\"}",
          "legendFormat": "total {{cluster}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ecs_cluster_disk_space_free_bytes{cluster=~\"$cluster\"}",
          "legendFormat": "free {{cluster}}",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ecs_cluster_disk_space_allocated_bytes{cluster=~\"$cluster\"}",
          "legendFormat": "allocated {{cluster}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Projected time to full",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ecs_cluster_disk_space_free_bytes{cluster=~\"$cluster\"} / clamp_min(-deriv(ecs_cluster_disk_space_free_bytes{cluster=~\"$cluster\"}[1h]), 1) / 86400",
          "legendFormat": "days to full",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 7
              },
              {
                "color": "green",
                "value": 30
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Top namespaces by usage",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "bytes",
          "links": [
            {
              "title": "Open Namespaces",
              "url": "/d/obs-namespaces?${__url_time_range}&var-cluster=${cluster}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "topk(10, ecs_namespace_used_bytes{cluster=~\"$cluster\"})",
          "legendFormat": "{{cluster}} {{namespace}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
