        "overrides": []
      },
      "options": {},
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "100 * (1 - ecs_cluster_disk_space_free_bytes{cluster=~\"$cluster\"} / ecs_cluster_disk_space_total_bytes{cluster=~\"$cluster\"})",
          "legendFormat": "{{cluster}}",
          "refId": "A"
