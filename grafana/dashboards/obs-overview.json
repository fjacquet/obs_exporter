    {
      "id": 12,
      "type": "timeseries",
      "title": "Transaction bandwidth",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 23
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "spanNulls": false
