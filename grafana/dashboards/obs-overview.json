        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ecs_cluster_good_nodes{cluster=~\"$cluster\"}",
          "legendFormat": "good {{cluster}}",
          "refId": "A"
