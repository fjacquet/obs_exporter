            {
              "title": "Open Maintenance & DT",
              "url": "/d/obs-maintenance?${__url_time_range}&var-cluster=${cluster}",
              "targetBlank": false
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none"
