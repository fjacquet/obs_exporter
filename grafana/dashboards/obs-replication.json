{
  "schemaVersion": 39,
  "editable": true,
  "style": "dark",
  "timezone": "",
  "title": "ObjectScale — Replication",
  "uid": "obs-replication",
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "tags": [
    "objectscale",
    "ecs",
    "dell",
    "object-storage",
    "obs-nav",
    "replication"
  ],
  "links": [
    {
      "type": "dashboards",
      "title": "ObjectScale dashboards",
      "tags": [
        "obs-nav"
      ],
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false,
      "icon": "external link"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(ecs_up, cluster)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "group",
        "label": "Replication group",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(ecs_replication_group_ingress_traffic{cluster=~\"$cluster\"}, rg)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Replication traffic by group",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "last",
            "max"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ecs_replication_group_ingress_traffic{cluster=~\"$cluster\",rg=~\"$group\"}",
          "legendFormat": "in {{cluster}} {{rg}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ecs_replication_group_egress_traffic{cluster=~\"$cluster\",rg=~\"$group\"}",
          "legendFormat": "out {{cluster}} {{rg}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Pending replication",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "spanNulls": false
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "last",
            "max"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ecs_replication_group_chunks_repo_pending_replication_bytes{cluster=~\"$cluster\",rg=~\"$group\"}",
          "legendFormat": "repo {{cluster}} {{rg}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ecs_replication_group_chunks_journal_pending_replication_bytes{cluster=~\"$cluster\",rg=~\"$group\"}",
          "legendFormat": "journal {{cluster}} {{rg}}",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ecs_replication_group_chunks_pending_xor_bytes{cluster=~\"$cluster\",rg=~\"$group\"}",
          "legendFormat": "xor {{cluster}} {{rg}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "RPO lag",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ecs_replication_group_rpo_lag_seconds{cluster=~\"$cluster\",rg=~\"$group\"}",
          "legendFormat": "{{cluster}} {{rg}}",
          "refId": "A"
        }
      ]
    }
  ]
}
