# EnvironmentFile for the obs_exporter systemd unit.
# Supplies cluster secrets referenced as ${VAR} in config.yaml.
#
# Install:  /etc/obs_exporter/obs_exporter.env   (chmod 0600, chown root:obs)

OBS1_PASSWORD=change-me
# OBS2_PASSWORD=change-me

# Optional: skip TLS certificate verification (INSECURE — dev/test only).
# config.yaml can reference it as ${OBS1_SKIP_CERTIFICATE}; defaults to false.
# OBS1_SKIP_CERTIFICATE=false
